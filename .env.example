# App
APP_NAME=PersonalAgent
APP_ENV=production
APP_TIMEZONE=America/New_York
APP_DEFAULT_LANGUAGE=en
APP_SUPPORTED_LANGUAGES=en,pt-BR,es
LOG_LEVEL=info

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook.php
ALLOWED_USER_ID=your_telegram_user_id   # get yours from @userinfobot — set 0 to disable (logs a warning)

# Group mode (optional) — per-person data inside Telegram groups.
# ALLOWED_USER_IDS : extra allowed user ids (comma-separated). Combined with ALLOWED_USER_ID.
# ALLOWED_GROUP_IDS: group chat ids the bot may operate in (comma-separated, negative numbers).
#                    Leave empty to disable groups entirely (DM only).
# BOT_USERNAME     : your bot's @username (without @). Required for the bot to react to
#                    free-text mentions/replies in groups; commands work without it.
ALLOWED_USER_IDS=
ALLOWED_GROUP_IDS=
BOT_USERNAME=

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.3

# Database
DB_PATH=storage/bot.sqlite
